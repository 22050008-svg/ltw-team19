# =====================================================================
# Database Configuration
# =====================================================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=shop

# =====================================================================
# Server Configuration
# =====================================================================
PORT=4321
NODE_ENV=development

# =====================================================================
# JWT Configuration
# =====================================================================
JWT_SECRET=your-super-secret-key-change-me
JWT_EXPIRE=7d

# =====================================================================
# Email Configuration (Optional)
# =====================================================================
# Nếu không cấu hình, email sẽ bị skip với warning log
# If not configured, emails will be skipped with warning log

# Gmail SMTP
MAIL_SERVICE=gmail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM_EMAIL=noreply@example.com
MAIL_FROM_NAME=Web Ban Hang

# Hoặc sử dụng SendGrid
# MAIL_HOST=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USER=apikey
# MAIL_PASSWORD=SG.xxxxxxxxxxxxxxxxxxxxx
# MAIL_FROM_EMAIL=noreply@company.com

# Hoặc sử dụng Microsoft 365 (Graph API)
# MAIL_TENANT_ID=your-tenant-id
# MAIL_CLIENT_ID=your-client-id
# MAIL_CLIENT_SECRET=your-client-secret
# MAIL_FROM_EMAIL=your-email@company.com

# =====================================================================
# Frontend Configuration
# =====================================================================
REACT_APP_API_URL=http://localhost:4321/api

# =====================================================================
# File Upload
# =====================================================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5MB

# =====================================================================
# Pagination
# =====================================================================
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100
